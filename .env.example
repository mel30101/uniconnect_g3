# ==========================================
# Conexión con el Backend (API)
# ==========================================
# URL base donde se encuentra corriendo el servidor backend.
# IMPORTANTE: Si pruebas la app en tu celular físico con la app de Expo Go, 
# 'localhost' no funcionará. Debes poner la IP local de tu computadora (ej: http://192.168.1.15:3000)
EXPO_PUBLIC_BACKEND_URL=http://tu_ip_local_o_localhost:3000